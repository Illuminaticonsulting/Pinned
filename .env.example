# ──────────────────────────────────────────────
# Pinned - Environment Configuration
# Copy this file to .env and fill in the values
# ──────────────────────────────────────────────

# ── Server ────────────────────────────────────
NODE_ENV=development
PORT=3001
WS_PORT=3002

# ── Database (PostgreSQL) ─────────────────────
DATABASE_URL=postgresql://pinned:pinned_secret@localhost:5432/pinned_db

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Authentication ────────────────────────────
JWT_SECRET=your-jwt-secret-key-change-me
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key-change-me

# ── BloFin Exchange API ───────────────────────
BLOFIN_API_KEY=your-blofin-api-key
BLOFIN_API_SECRET=your-blofin-api-secret
BLOFIN_PASSPHRASE=your-blofin-passphrase

# ── MEXC Exchange API ─────────────────────────
MEXC_API_KEY=your-mexc-api-key
MEXC_API_SECRET=your-mexc-api-secret

# ── AI Service ────────────────────────────────
AI_SERVICE_URL=http://localhost:8000

# ── Telegram Notifications ───────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ── Email (SendGrid) ─────────────────────────
SENDGRID_API_KEY=your-sendgrid-api-key
