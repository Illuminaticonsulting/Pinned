# ──────────────────────────────────────────────
# Pinned - Environment Configuration
# Copy this file to .env and fill in the values
# ──────────────────────────────────────────────

# ── Server ────────────────────────────────────
NODE_ENV=dev
PORT=3001
WS_PORT=3002

# ── Database (PostgreSQL / TimescaleDB) ───────
DATABASE_URL=postgresql://pinned:pinned_secret@localhost:5432/pinned_db
POSTGRES_PASSWORD=pinned_secret

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://:your-redis-password@localhost:6379
REDIS_PASSWORD=your-redis-password

# ── Authentication (REQUIRED: min 32 chars) ───
JWT_SECRET=CHANGE-ME-use-openssl-rand-base64-48
JWT_REFRESH_SECRET=CHANGE-ME-use-openssl-rand-base64-48

# ── BloFin Exchange API ───────────────────────
BLOFIN_API_KEY=your-blofin-api-key
BLOFIN_API_SECRET=your-blofin-api-secret
BLOFIN_PASSPHRASE=your-blofin-passphrase

# ── MEXC Exchange API ─────────────────────────
MEXC_API_KEY=your-mexc-api-key
MEXC_API_SECRET=your-mexc-api-secret

# ── AI Service ────────────────────────────────
AI_SERVICE_URL=http://localhost:8000

# ── Telegram Notifications ───────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ── Email (SendGrid) ─────────────────────────
SENDGRID_API_KEY=your-sendgrid-api-key
